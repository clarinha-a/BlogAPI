generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

model Post {
  id Int @id @default(autoincrement())
  slug String @unique
  authorId Int
  title String
  body String
  status PostStatus @default(DRAFT)
  createdAt DateTime @default(now())
  updateAt DateTime?
  cover String
  tags String @default("")
  author User? @relation(fields: [authorId], references: [id])
}

model User {
  id Int @id @default(autoincrement())
  status Boolean @default(true)
  name String
  email String @unique
  password String
  posts Post[]
}